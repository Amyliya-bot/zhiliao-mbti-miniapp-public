/* ---- 知聊MBTI对话测试 - 全局样式 ---- */

page {
  font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  background: #F2F2F7;
  color: #1C1C1E;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}

/* Layout */
.page-wrap {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: #F2F2F7;
  overflow: hidden;
}

/* Scrollable content */
.scroll-content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.scroll-content::-webkit-scrollbar {
  display: none;
}

/* Full page white */
.page-wrap-white {
  background: #FFFFFF;
}

/* Full page black */
.page-wrap-black {
  background: #000000;
}

/* Glass effect */
.glass {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1px solid rgba(255,255,255,0.8);
}

/* Card style */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  border: 1px solid #F2F2F7;
}

/* Fade animation */
.fade-up {
  animation: fadeUp 0.6s cubic-bezier(.22,1,.36,1) both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Tap feedback */
.tap-active {
  transition: all 0.1s;
}
.tap-active:active {
  transform: scale(0.97);
}

/* Status bar spacer — reserves space for system status bar */
.status-spacer {
  height: 120rpx;
  background: #FFFFFF;
  flex-shrink: 0;
}

/* Entry arrow shared */
.entry-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  font-weight: 300;
}

/* Utility */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Utility */
.hidden {
  display: none !important;
}

/* Tab Bar Styles */
.tabbar {
  height: 164rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-top: 1px solid rgba(0,0,0,0.05);
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 12rpx;
  flex-shrink: 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: #1C1C1E;
  transition: color 0.15s;
}

.tab-item.active {
  color: #1C1C1E;
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  color: currentColor;
}

.tab-home .home-roof {
  width: 28rpx;
  height: 28rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
  position: absolute;
  top: 9rpx;
  border-radius: 3rpx 0 0 0;
}

.tab-home .home-body {
  width: 30rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 8rpx 8rpx;
  position: absolute;
  bottom: 7rpx;
}

.tab-report {
  align-items: flex-end;
  gap: 5rpx;
}

.report-bar {
  width: 9rpx;
  background: currentColor;
  border-radius: 6rpx;
}

.report-bar.short { height: 20rpx; }
.report-bar.mid { height: 30rpx; }
.report-bar.tall { height: 40rpx; }

.tab-mine .mine-head {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  position: absolute;
  top: 6rpx;
}

.tab-mine .mine-body {
  width: 34rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: none;
  border-radius: 22rpx 22rpx 0 0;
  position: absolute;
  bottom: 5rpx;
}

.tab-label {
  font-size: 28rpx;
  font-weight: 700;
}

.tab-indicator {
  width: 40rpx;
  height: 6rpx;
  background: transparent;
  border-radius: 4rpx;
  transition: all 0.15s;
}

.tab-item.active .tab-indicator {
  width: 40rpx;
  height: 6rpx;
  background: #1C1C1E;
  border-radius: 4rpx;
}
