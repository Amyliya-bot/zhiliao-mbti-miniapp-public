/* 选择测试方式页 */

.quiz-nav {
  height: 88rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #F2F2F7;
  position: relative;
  flex-shrink: 0;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  font-size: 56rpx;
  color: #1C1C1E;
  padding: 8rpx 16rpx;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.select-desc {
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.6;
  display: block;
  margin-bottom: 40rpx;
}

.select-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid #F2F2F7;
  position: relative;
}

.select-card-badge {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: white;
}

.select-card-badge.deep {
  background: #1C1C1E;
}

.select-card-badge.fast {
  background: #007AFF;
}

.select-card-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 8rpx;
}

.select-card-desc {
  font-size: 26rpx;
  color: #8E8E93;
  display: block;
  margin-bottom: 24rpx;
}

.select-card-features {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feature-item {
  font-size: 24rpx;
  color: #8E8E93;
  padding-left: 20rpx;
  position: relative;
}

.feature-item::before {
  content: '·';
  position: absolute;
  left: 4rpx;
  color: #C7C7CC;
}

.select-note {
  font-size: 22rpx;
  color: #C7C7CC;
  text-align: center;
  display: block;
  margin-top: 16rpx;
}

.select-disclaimer {
  font-size: 22rpx;
  color: #C7C7CC;
  text-align: center;
  display: block;
  margin-top: 8rpx;
}
