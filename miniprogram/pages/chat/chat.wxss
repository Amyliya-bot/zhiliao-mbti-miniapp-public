/* 对话页样式 - 含打字机动效 */

.chat-nav {
  height: 88rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #F2F2F7;
  position: relative;
  flex-shrink: 0;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  font-size: 56rpx;
  color: #1C1C1E;
  padding: 8rpx 16rpx;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}

/* Progress */
.chat-progress {
  padding: 32rpx 40rpx 16rpx;
  background: #FFFFFF;
  flex-shrink: 0;
}

.progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.progress-scene {
  font-size: 24rpx;
  color: #8E8E93;
}

.progress-bar {
  height: 6rpx;
  background: #F2F2F7;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1C1C1E;
  border-radius: 4rpx;
  transition: width 0.5s;
}

.daily-counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #C7C7CC;
  margin-top: 8rpx;
}

/* Chat Messages */
.chat-msgs {
  flex: 1;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  overflow-y: scroll;
  overflow-x: hidden;
  box-sizing: border-box;
}

.msg-row {
  display: flex;
  margin-bottom: 24rpx;
  animation: msgIn 0.35s cubic-bezier(.22,1,.36,1) both;
}

.msg-row.ai {
  align-items: flex-end;
  gap: 16rpx;
}

.msg-row.user {
  display: flex;
  justify-content: flex-end;
  overflow: hidden;
}

@keyframes msgIn {
  from { opacity: 0; transform: translateY(24rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #1C1C1E;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bubble-ai {
  background: rgba(28,28,30,0.06);
  border-radius: 36rpx 36rpx 36rpx 8rpx;
  padding: 24rpx 32rpx;
  max-width: 560rpx;
  font-size: 30rpx;
  color: #1C1C1E;
  line-height: 1.6;
  word-break: break-all;
  overflow: hidden;
  min-width: 0;
}

.bubble-user {
  background: #1C1C1E;
  border-radius: 36rpx 36rpx 8rpx 36rpx;
  padding: 24rpx 32rpx;
  max-width: 520rpx;
  font-size: 30rpx;
  color: white;
  line-height: 1.6;
  word-break: break-all;
  min-width: 0;
  overflow: hidden;
  text-align: left;
  box-sizing: border-box;
}

.bubble-user text,
.bubble-ai text {
  word-break: break-all;
  white-space: normal;
}

.bubble-txt {
  word-break: break-all;
  white-space: normal;
}

/* Typing Cursor */
.typing-cursor {
  animation: blink 0.6s infinite;
  color: #1C1C1E;
  font-weight: 300;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* Typing Indicator (dots) */
.typing-indicator {
  background: rgba(28,28,30,0.06);
  border-radius: 36rpx 36rpx 36rpx 8rpx;
  padding: 28rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  background: #C7C7CC;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-12rpx); opacity: 1; }
}

/* Scene Complete */
.msg-row.system {
  justify-content: center;
}

.scene-complete {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
  width: 100%;
}

.scene-tag {
  background: #F2F2F7;
  border-radius: 40rpx;
  padding: 8rpx 28rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

/* Complete Bar */
.chat-complete-bar {
  background: #FFFFFF;
  border-top: 1px solid #F2F2F7;
  padding: 24rpx 32rpx 48rpx;
  flex-shrink: 0;
  animation: msgIn 0.35s cubic-bezier(.22,1,.36,1) both;
}
.complete-btn {
  background: #1C1C1E;
  color: white;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}
.complete-btn:active {
  transform: scale(0.97);
  background: #2C2C2E;
}
.complete-btn.disabled {
  opacity: 0.55;
}

/* Input Bar */
.chat-input-bar {
  background: #FFFFFF;
  border-top: 1px solid #F2F2F7;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-shrink: 0;
}

.input-wrap {
  flex: 1;
  background: rgba(118,118,128,0.12);
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
}

.chat-input {
  width: 100%;
  background: transparent;
  font-size: 30rpx;
  color: #1C1C1E;
}

.input-counter {
  font-size: 22rpx;
  color: #C7C7CC;
  margin-top: 8rpx;
  display: block;
  text-align: right;
}

.send-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #1C1C1E;
  color: white;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.disabled {
  opacity: 0.3;
}
