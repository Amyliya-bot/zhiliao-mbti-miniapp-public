/* 首页样式 */

.hall-scroll {
  flex: 1;
  overflow-y: scroll;
  overflow-x: hidden;
  box-sizing: border-box;
  padding: 32rpx 40rpx 16rpx;
}

/* Header */
.hall-header {
  background: #FFFFFF;
  padding: 24rpx 40rpx 32rpx;
  flex-shrink: 0;
}

/* Greeting */
.greeting-title {
  font-size: 68rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.5px;
  display: block;
}

.greeting-sub {
  font-size: 32rpx;
  font-weight: 400;
  color: #C7C7CC;
  margin-left: 8rpx;
}

.greeting-desc {
  font-size: 28rpx;
  color: #8E8E93;
  display: block;
  margin-top: 12rpx;
}

/* Section */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.section-badge {
  font-size: 24rpx;
  color: #C7C7CC;
}

.recent-limit-hint {
  font-size: 20rpx;
  color: #8E8E93;
  display: block;
  padding: 0 0 12rpx;
}

/* Entry Cards */
.entry-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 36rpx;
  border: 1px solid #F2F2F7;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.entry-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 2rpx solid #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.entry-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.entry-badge {
  font-size: 24rpx;
  font-weight: 400;
  color: #8E8E93;
  margin-left: 8rpx;
}

.entry-desc {
  font-size: 26rpx;
  color: #8E8E93;
}

.entry-limit {
  font-size: 24rpx;
  color: #34C759;
  margin-top: 4rpx;
}

.entry-card.disabled {
  opacity: 0.45;
  pointer-events: none;
}
.entry-card.disabled .entry-limit {
  color: #FF3B30;
}

.entry-rules-link {
  font-size: 24rpx;
  color: #8E8E93;
  padding: 8rpx 0 8rpx 8rpx;
}

.entry-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  font-weight: 300;
  flex-shrink: 0;
}

/* ==================== Chat Icon — Black Speech Bubble on White ==================== */

.chat-icon-wrap {
  overflow: visible;
}

.bubble-body {
  width: 56rpx;
  height: 44rpx;
  background: #1C1C1E;
  border-radius: 18rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Tail on bottom-left (🗨 style) */
.bubble-body::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 4rpx;
  width: 0;
  height: 0;
  border-top: 14rpx solid #1C1C1E;
  border-right: 14rpx solid transparent;
}

/* Three white dots */
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FFFFFF;
  margin: 0 5rpx;
}

/* Dot bounce animation */
.dot.bounce {
  animation: dotBounce 0.42s ease forwards;
}

.dot-1.bounce { animation-delay: 0s; }
.dot-2.bounce { animation-delay: 0.14s; }
.dot-3.bounce { animation-delay: 0.28s; }

@keyframes dotBounce {
  0%   { transform: translateY(0); }
  30%  { transform: translateY(-12rpx); }
  60%  { transform: translateY(0); }
  100% { transform: translateY(0); }
}

/* ==================== Quiz Icon — Black Pencil at 45deg on White ==================== */

.pencil-icon-wrap {
  overflow: visible;
}

.pencil-outer {
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: rotate(-45deg);
  transform-origin: 50% 50%;
}

/* Pencil tip swing — two full oscillations */
.pencil-outer.swing {
  animation: pencilSwing 0.6s ease forwards;
}

@keyframes pencilSwing {
  0%   { transform: rotate(-45deg); }
  10%  { transform: rotate(-60deg); }
  23%  { transform: rotate(-33deg); }
  36%  { transform: rotate(-45deg); }
  49%  { transform: rotate(-56deg); }
  62%  { transform: rotate(-36deg); }
  75%  { transform: rotate(-45deg); }
  100% { transform: rotate(-45deg); }
}

.pencil-eraser {
  width: 20rpx;
  height: 12rpx;
  background: #636366;
  border-radius: 3rpx 3rpx 0 0;
}

.pencil-body {
  width: 20rpx;
  height: 36rpx;
  background: #1C1C1E;
  position: relative;
}

.pencil-stripe {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  height: 3rpx;
  background: #FFFFFF;
  border-radius: 1.5rpx;
  top: 8rpx;
}

.stripe-2 {
  top: 20rpx;
}

.pencil-tip {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 20rpx solid #1C1C1E;
}

.pencil-point {
  width: 0;
  height: 0;
  border-left: 3rpx solid transparent;
  border-right: 3rpx solid transparent;
  border-top: 6rpx solid #FFFFFF;
  margin-top: -5rpx;
}

/* ==================== Recent Reports ==================== */

.recent-empty {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  border: 2rpx solid #F2F2F7;
}

.recent-empty-text {
  font-size: 26rpx;
  color: #8E8E93;
}

.recent-list {
  /* flows naturally in page scroll */
}

.recent-item-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.recent-item-wrap:last-child {
  margin-bottom: 0;
}

.recent-delete-btn {
  position: absolute;
  right: 0;
  top: 2rpx;
  bottom: 2rpx;
  width: 140rpx;
  background: #E53935;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 22rpx 22rpx 0;
  letter-spacing: 2rpx;
}

.recent-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #F2F2F7;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateX(0) translateZ(0);
  will-change: transform;
}

.recent-item.swiped {
  transform: translateX(-140rpx) translateZ(0);
  border-radius: 24rpx 0 0 24rpx;
}

.recent-type-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #1C1C1E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recent-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.recent-date {
  font-size: 24rpx;
  color: #C7C7CC;
}

/* Limit Toast */
.limit-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(28,28,30,0.92);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 32rpx 48rpx;
  border-radius: 24rpx;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s;
  white-space: nowrap;
}
.limit-toast.show {
  opacity: 1;
}

/* ==================== Rules Bottom Sheet ==================== */

.rules-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  z-index: 300;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.25s ease both;
}

.rules-overlay.hidden {
  display: none;
}

.rules-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 48rpx 96rpx;
  animation: sheetUp 0.35s cubic-bezier(.22,1,.36,1) both;
  max-height: 85vh;
  overflow-y: auto;
}

.rules-handle {
  width: 64rpx;
  height: 8rpx;
  background: #E5E5EA;
  border-radius: 4rpx;
  margin: 0 auto 36rpx;
}

.rules-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 36rpx;
}

.rules-body {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.rules-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rules-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.rules-text {
  font-size: 28rpx;
  color: #8E8E93;
  line-height: 1.7;
}

.rules-disclaimer {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #C7C7CC;
  margin-top: 32rpx;
}

.rules-close {
  margin-top: 44rpx;
  background: #1C1C1E;
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.rules-close:active {
  transform: scale(0.97);
  background: #2C2C2E;
}

/* Closing animation */
.rules-overlay.closing {
  animation: fadeOut 0.35s ease both;
}
.rules-overlay.closing .rules-sheet {
  animation: sheetDown 0.35s cubic-bezier(.55,0,.6,1) both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes sheetUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
@keyframes sheetDown {
  from { transform: translateY(0); }
  to { transform: translateY(100%); }
}
