/* 传统测试页样式 */

.quiz-nav {
  height: 88rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #F2F2F7;
  position: relative;
  flex-shrink: 0;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  font-size: 56rpx;
  color: #1C1C1E;
  padding: 8rpx 16rpx;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.flex-1 { flex: 1; }
.flex-col { display: flex; flex-direction: column; }
/* Progress */
.quiz-progress {
  background: #FFFFFF;
  padding: 32rpx 40rpx 24rpx;
  flex-shrink: 0;
}

.progress-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.progress-pct {
  font-size: 24rpx;
  color: #C7C7CC;
}

.progress-track {
  height: 8rpx;
  background: #E5E5EA;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-track-fill {
  height: 100%;
  background: #1C1C1E;
  border-radius: 4rpx;
  transition: width 0.4s cubic-bezier(.22,1,.36,1);
}

/* Question */
.question-area {
  animation: fadeIn 0.35s cubic-bezier(.22,1,.36,1) both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(24rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.question-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1C1E;
  line-height: 1.5;
  display: block;
  margin-bottom: 48rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 64rpx;
}

.option-btn {
  background: #FFFFFF;
  border: 3rpx solid #E5E5EA;
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.2s;
}

.option-btn.selected {
  border-color: #1C1C1E;
  background: #F8F8F8;
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #8E8E93;
  flex-shrink: 0;
  transition: all 0.2s;
}

.option-btn.selected .option-letter {
  background: #1C1C1E;
  color: white;
}

.option-text {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
}

/* Nav buttons */
.nav-btns {
  display: flex;
  gap: 24rpx;
}

.nav-btn {
  flex: 1;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 28rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  text-align: center;
  line-height: 1;
}

.nav-btn::after {
  border: none;
}

.nav-btn.primary {
  background: #1C1C1E;
  color: white;
  border-color: #1C1C1E;
}

.nav-btn.primary:active {
  background: #2C2C2E;
}

.nav-btn.disabled {
  opacity: 0.3;
}

/* Result Card */
.result-card {
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 64rpx 48rpx;
  text-align: center;
}

.result-type-badge {
  width: 200rpx;
  height: 200rpx;
  border-radius: 48rpx;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 72rpx;
  letter-spacing: 4rpx;
  margin: 0 auto 32rpx;
  color: #1C1C1E;
}

.result-type-text {
  font-size: 56rpx;
  font-weight: 900;
  color: #1C1C1E;
  letter-spacing: 4rpx;
  display: block;
}

.result-type-name {
  font-size: 28rpx;
  color: #8E8E93;
  display: block;
  margin-top: 12rpx;
}

.result-dims {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dim-label {
  font-size: 24rpx;
  color: #8E8E93;
  white-space: nowrap;
}

.dim-bar {
  flex: 1;
  height: 12rpx;
  background: #F2F2F7;
  border-radius: 6rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  background: #1C1C1E;
  border-radius: 6rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #8E8E93;
  display: block;
  margin-top: 48rpx;
  line-height: 1.5;
}

.result-cta {
  background: #1C1C1E;
  color: white;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  margin-top: 48rpx;
  font-size: 30rpx;
  width: 100%;
}

.result-cta::after { border: none; }

.result-retry {
  width: 100%;
  color: #8E8E93;
  font-size: 26rpx;
  margin-top: 24rpx;
  background: transparent;
  text-align: center;
}

.result-retry::after { border: none; }

/* Validation Error */
.quiz-error {
  color: #FF3B30;
  font-size: 24rpx;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
  opacity: 0;
  transition: opacity 0.2s;
}
.quiz-error.visible {
  opacity: 1;
}
