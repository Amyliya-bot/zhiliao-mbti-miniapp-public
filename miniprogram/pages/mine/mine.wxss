/* 我的页面样式 */

.mine-header {
  background: #FFFFFF;
  padding: 24rpx 40rpx 32rpx;
}

.mine-header-title {
  font-size: 68rpx;
  font-weight: 800;
  color: #1C1C1E;
}

/* Stats */
.stats-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #8E8E93;
  display: block;
  margin-top: 12rpx;
}

.stat-divider {
  width: 2rpx;
  height: 84rpx;
  background: #F2F2F7;
}

/* Menu */
.menu-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx 40rpx;
}

/* Reset button defaults for open-type="share" menu item */
.menu-btn {
  width: 100%;
  background: transparent;
  border: none;
  line-height: normal;
  font-size: inherit;
  text-align: left;
  border-radius: 0;
}
.menu-btn::after {
  border: none;
}

.menu-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
}

.menu-divider {
  height: 2rpx;
  background: #F2F2F7;
  margin: 0 40rpx;
}

/* Version */
.version-info {
  text-align: center;
  padding: 48rpx 0 80rpx;
}

.version-text {
  font-size: 24rpx;
  color: #C7C7CC;
  display: block;
}

.version-sub {
  font-size: 24rpx;
  color: #C7C7CC;
  display: block;
  margin-top: 8rpx;
}
