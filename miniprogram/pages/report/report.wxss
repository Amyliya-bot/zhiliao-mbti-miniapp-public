/* 报告页样式 */

.report-scroll {
  flex: 1;
  overflow-y: scroll;
  overflow-x: hidden;
  box-sizing: border-box;
  padding: 32rpx 40rpx;
}

.report-header {
  background: #FFFFFF;
  padding: 24rpx 40rpx 32rpx;
}

.report-header-title {
  font-size: 68rpx;
  font-weight: 800;
  color: #1C1C1E;
  display: block;
}

.report-header-sub {
  font-size: 26rpx;
  color: #8E8E93;
  display: block;
  margin-top: 8rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 128rpx;
}

.empty-icon {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04);
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8E8E93;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 56rpx;
  white-space: pre-line;
}

.empty-cta {
  background: #1C1C1E;
  color: white;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}

.empty-cta::after { border: none; }

/* History List */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-type-badge {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 36rpx;
  color: #1C1C1E;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
}

.history-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.history-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.history-bars {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.mini-bar {
  flex: 1;
  height: 10rpx;
  background: #F2F2F7;
  border-radius: 6rpx;
  overflow: hidden;
}

.mini-bar-fill {
  height: 100%;
  background: #1C1C1E;
  border-radius: 6rpx;
  width: 0;
  transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Staggered delays for the 4 bars */
.mini-bar:nth-child(1) .mini-bar-fill { transition-delay: 0s; }
.mini-bar:nth-child(2) .mini-bar-fill { transition-delay: 0.1s; }
.mini-bar:nth-child(3) .mini-bar-fill { transition-delay: 0.2s; }
.mini-bar:nth-child(4) .mini-bar-fill { transition-delay: 0.3s; }

.history-date {
  font-size: 24rpx;
  color: #C7C7CC;
}

.entry-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  flex-shrink: 0;
}

/* Swipe-to-delete */
.history-item-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 2rpx;
  bottom: 2rpx;
  width: 156rpx;
  background: #E53935;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 28rpx 28rpx 0;
  letter-spacing: 2rpx;
}

.history-item {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  border: 2rpx solid #E5E5EA;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateX(0) translateZ(0);
  will-change: transform;
}

.history-item.swiped {
  transform: translateX(-156rpx) translateZ(0);
  border-radius: 32rpx 0 0 32rpx;
}

/* Trim Notice */
.trim-notice {
  margin: 12rpx 40rpx 0;
  padding: 12rpx 28rpx;
  background: #F8F8FA;
  border-radius: 12rpx;
  text-align: center;
}
.trim-notice-text {
  font-size: 20rpx;
  color: #8E8E93;
  line-height: 1.5;
}
