/* 结果页 — 深色背景 */

/* Override page-wrap overflow to allow scrolling */
.page-wrap-black {
  overflow-y: auto;
}

/* Ambient Glow */
.glow {
  position: absolute;
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  pointer-events: none;
}
.glow-top {
  top: -120rpx;
  left: -120rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
}
.glow-bot {
  bottom: -100rpx;
  right: -140rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);
}

/* ─── Type Hero ─── */
.hero {
  margin-top: 120rpx;
  text-align: center;
}
.type-badge {
  width: 168rpx;
  height: 168rpx;
  border-radius: 40rpx;
  background: #FFFFFF;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1C1C1E;
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: 6rpx;
  box-shadow: 0 24rpx 64rpx rgba(255,255,255,0.12);
}
.type-name {
  display: block;
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.type-quote {
  display: block;
  color: rgba(255,255,255,0.3);
  font-size: 26rpx;
  margin-top: 16rpx;
  max-width: 560rpx;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}

/* ─── Dimension Bars ─── */
.dims-block {
  margin-top: 72rpx;
  padding: 0 48rpx;
}
.dims-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}
.dims-header-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255,255,255,0.08);
}
.dims-header-label {
  color: rgba(255,255,255,0.25);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
}

/* Each dimension group */
.dim-group {
  margin-bottom: 36rpx;
  text-align: center;
}

/* Each dimension row */
.dim-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* Borderline indicator */
.dim-borderline {
  color: rgba(255,255,255,0.2);
  font-size: 20rpx;
  margin-top: 12rpx;
  padding: 6rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 20rpx;
  display: inline-block;
}

/* Labels on both sides */
.dim-info {
  width: 128rpx;
  flex-shrink: 0;
}
.dim-info-left {
  text-align: right;
}
.dim-info-right {
  text-align: left;
}
.dim-pole {
  display: block;
  color: rgba(255,255,255,0.5);
  font-size: 20rpx;
}
.dim-pct {
  display: block;
  color: rgba(255,255,255,0.35);
  font-size: 32rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* Track */
.dim-track {
  flex: 1;
  height: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  background: rgba(255,255,255,0.06);
}

/* Fills */
.dim-fill {
  height: 100%;
  transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
}
.dim-fill-white {
  background: #FFFFFF;
  border-radius: 8rpx 0 0 8rpx;
}
.dim-fill-dark {
  background: rgba(255,255,255,0.1);
  border-radius: 0 8rpx 8rpx 0;
}

/* Stagger dim row animations */
.dim-row:nth-child(2) .dim-fill { transition-delay: 0.12s; }
.dim-row:nth-child(3) .dim-fill { transition-delay: 0.24s; }
.dim-row:nth-child(4) .dim-fill { transition-delay: 0.36s; }
.dim-row:nth-child(5) .dim-fill { transition-delay: 0.48s; }

/* ─── Impression ─── */
.impression {
  margin: 56rpx 48rpx 0;
  background: rgba(255,255,255,0.04);
  border: 2rpx solid rgba(255,255,255,0.06);
  border-radius: 36rpx;
  padding: 40rpx;
}
.impr-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.impr-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #1C1C1E;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.impr-label {
  color: rgba(255,255,255,0.45);
  font-size: 24rpx;
  font-weight: 500;
}
.impr-text {
  color: rgba(255,255,255,0.55);
  font-size: 28rpx;
  line-height: 1.75;
}

/* ─── Disclaimer ─── */
.disclaimer {
  display: block;
  text-align: center;
  color: rgba(255,255,255,0.12);
  font-size: 22rpx;
  margin-top: 32rpx;
}

/* ─── Actions ─── */
.actions {
  margin-top: 40rpx;
  padding: 0 48rpx 96rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.btn-primary {
  background: #FFFFFF;
  color: #1C1C1E;
  border-radius: 48rpx;
  padding: 30rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
  transition: transform 0.2s;
}
.btn-primary:active { transform: scale(0.97); }
.btn-row {
  display: flex;
  gap: 20rpx;
}
.btn-secondary {
  flex: 1;
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  text-align: center;
  transition: all 0.2s;
}
.btn-secondary:active {
  background: rgba(255,255,255,0.08);
  transform: scale(0.97);
}

/* Share button — matches .btn-secondary, overrides WeChat button defaults */
.btn-secondary-share {
  flex: 1;
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  text-align: center;
  background: transparent;
  margin: 0;
  line-height: 1.4;
  box-sizing: border-box;
}
.btn-secondary-share::after {
  border: none;
}
.btn-secondary-share:active {
  background: rgba(255,255,255,0.08);
  transform: scale(0.97);
}

/* ─── Fade-in ─── */
.fade-in {
  animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.fade-in.d0 { animation-delay: 0s; }
.fade-in.d1 { animation-delay: 0.1s; }
.fade-in.d2 { animation-delay: 0.25s; }
.fade-in.d3 { animation-delay: 0.35s; }
.fade-in.d4 { animation-delay: 0.45s; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(36rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Hidden canvas */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 500px;
  height: 1000px;
}

/* Full-width button */
.btn-secondary.btn-block {
  flex: none;
  width: 100%;
  margin-top: 4rpx;
}

/* Share Preview Overlay */
.share-preview-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.share-preview-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #1C1C1E;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  max-width: 85vw;
  max-height: 85vh;
  overflow: hidden;
}

.share-preview-img {
  width: 500rpx;
  max-height: 65vh;
  border-radius: 16rpx;
}

.share-preview-btns {
  display: flex;
  gap: 28rpx;
  margin-top: 44rpx;
}

.sp-btn {
  padding: 22rpx 52rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.sp-btn-save {
  background: #FFFFFF;
  color: #1C1C1E;
}

.sp-btn-save:active {
  transform: scale(0.96);
}

.sp-btn-cancel {
  border: 2rpx solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.7);
}

.sp-btn-cancel:active {
  background: rgba(255,255,255,0.08);
}
