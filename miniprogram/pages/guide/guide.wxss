/* 引导页样式 */
page {
  background: #F2F2F7;
}

.swiper {
  width: 750rpx;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
}

.slide-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.slide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 80rpx;
  width: 100%;
  height: 100%;
}

/* Slide 0 */
.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 44rpx;
  background: #1C1C1E;
  color: white;
  font-size: 72rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.1);
  margin-bottom: 64rpx;
}

.slide-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.5px;
  text-align: center;
  line-height: 1.3;
  margin-bottom: 24rpx;
  white-space: pre-line;
}

.slide-desc {
  color: #8E8E93;
  font-size: 32rpx;
  line-height: 1.6;
  text-align: center;
  white-space: pre-line;
}

.scroll-hint {
  position: absolute;
  bottom: 360rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2px solid #C7C7CC;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C7C7CC;
  font-size: 36rpx;
  animation: bounce 2s infinite;
}

/* Slide 1, 2 */
.slide-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.slide-title-sm {
  font-size: 48rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.5px;
  display: block;
}

.slide-desc-sm {
  font-size: 24rpx;
  color: #8E8E93;
  display: block;
  margin-top: 12rpx;
}

.step-list {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-card {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1px solid rgba(255,255,255,0.8);
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.step-num {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1C1C1E;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.step-label {
  color: #1C1C1E;
  font-size: 30rpx;
  font-weight: 600;
}

.step-desc {
  color: #8E8E93;
  font-size: 24rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 96rpx;
}

.tip-card {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1px solid rgba(255,255,255,0.8);
  border-radius: 40rpx;
  padding: 48rpx;
  text-align: center;
}

.tip-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 24rpx;
}

.tip-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
}

.tip-desc {
  font-size: 24rpx;
  color: #8E8E93;
  display: block;
  margin-top: 12rpx;
}

.start-area {
  text-align: center;
}

.start-btn {
  background: #1C1C1E;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 96rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
  transition: all 0.2s;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: scale(0.95);
  background: #2C2C2E;
}

.teaser-text {
  color: #8E8E93;
  font-size: 24rpx;
  display: block;
  margin-top: 32rpx;
}

/* Dots */
.dots-wrap {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #C7C7CC;
  transition: all 0.3s cubic-bezier(.22,1,.36,1);
}

.dot.active {
  width: 52rpx;
  border-radius: 8rpx;
  background: #1C1C1E;
}

/* Skip */
.skip-btn {
  position: absolute;
  top: 112rpx;
  right: 48rpx;
  color: #8E8E93;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
}

/* Animations */
.fade-up {
  animation: fadeUp 0.6s cubic-bezier(.22,1,.36,1) both;
}
.fade-up.d1 { animation-delay: 0.1s; }
.fade-up.d2 { animation-delay: 0.2s; }
.fade-up.d3 { animation-delay: 0.3s; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(48rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(12rpx); }
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

/* Privacy Modal */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.privacy-modal {
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 48rpx 40rpx 64rpx;
  width: 100%;
  max-height: 75vh;
}

.privacy-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C1C1E;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.privacy-modal-text {
  font-size: 26rpx;
  color: #3A3A3C;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.privacy-modal-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #F2F2F7;
  border-radius: 20rpx;
}

.privacy-modal-item {
  font-size: 24rpx;
  color: #636366;
  line-height: 1.6;
}

.privacy-modal-links {
  text-align: center;
  margin-bottom: 32rpx;
}

.privacy-link {
  font-size: 24rpx;
  color: #007AFF;
}

.privacy-modal-btns {
  display: flex;
  gap: 20rpx;
}

.privacy-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.privacy-btn.decline {
  border: 2rpx solid #E5E5EA;
  color: #8E8E93;
}

.privacy-btn.agree {
  background: #1C1C1E;
  color: #FFFFFF;
}
